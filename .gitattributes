############################################

# Normalize line endings

############################################

* text=auto

############################################

# C# source files

############################################

*.cs           text diff=csharp
*.csx          text diff=csharp
*.csproj       text
*.sln          text
*.props        text
*.targets      text

############################################

# JSON / Config

############################################

*.json         text
*.config       text
*.xml          text
*.yml          text
*.yaml         text

############################################

# Web files

############################################

*.html         text diff=html
*.css          text diff=css
*.js           text diff=javascript
*.ts           text diff=javascript
*.scss         text
*.sass         text

############################################

# Razor

############################################

*.cshtml       text
*.razor        text

############################################

# Shell / scripts

############################################

*.sh           text eol=lf
*.bash         text eol=lf
*.ps1          text eol=crlf
*.cmd          text eol=crlf
*.bat          text eol=crlf

############################################

# Binary files

############################################

*.png          binary
*.jpg          binary
*.jpeg         binary
*.gif          binary
*.bmp          binary
*.ico          binary
*.pdf          binary
*.zip          binary
*.gz           binary
*.7z           binary
*.dll          binary
*.exe          binary
*.pdb          binary
*.so           binary
*.dylib        binary

############################################

# Database files

############################################

*.mdf          binary
*.ldf          binary
*.sqlite       binary
*.db           binary

############################################

# Git merge handling

############################################

*.csproj       merge=union
*.sln          merge=union
