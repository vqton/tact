@model Web.Controllers.AuditIndexVm

<div class="table-responsive">
    <table class="table table-striped table-hover align-middle">
        <thead class="table-light">
            <tr>
                <th style="width: 170px;">Thời gian (UTC)</th>
                <th style="width: 220px;">Người dùng</th>
                <th style="width: 180px;">Đối tượng</th>
                <th style="width: 140px;">ID đối tượng</th>
                <th style="width: 140px;">Hành động</th>
                <th>Thay đổi</th>
                <th style="width: 140px;">IP</th>
            </tr>
        </thead>
        <tbody>
            @if (Model.Items.Count == 0)
            {
                <tr>
                    <td colspan="7" class="text-center text-muted py-4">Không có dữ liệu nhật ký kiểm tra.</td>
                </tr>
            }
            else
            {
                @foreach (var item in Model.Items)
                {
                    <tr>
                        <td>@item.Timestamp.ToString("dd/MM/yyyy HH:mm:ss")</td>
                        <td>@item.UserId</td>
                        <td>@item.EntityType</td>
                        <td>@item.EntityId</td>
                        <td>@item.Action</td>
                        <td class="text-break">@item.Changes</td>
                        <td>@(string.IsNullOrWhiteSpace(item.IpAddress) ? "-" : item.IpAddress)</td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>
