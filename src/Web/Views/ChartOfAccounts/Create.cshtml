@model Web.Models.ChartOfAccounts.ChartOfAccountFormVm
@using Microsoft.AspNetCore.Mvc.Rendering
@{
    var parentOptions = ViewBag.ParentOptions as List<SelectListItem> ?? new List<SelectListItem>();
}

<div class="card">
    <div class="card-body">
        <h2 class="h5 mb-3">Them tai khoan</h2>
        <form asp-action="Create"
              asp-controller="ChartOfAccounts"
              method="post"
              hx-post="@Url.Action("Create", "ChartOfAccounts")"
              hx-target="#account-list"
              hx-swap="innerHTML">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="form-floating mb-3">
                <input asp-for="Code" class="form-control" placeholder="Ma TK" />
                <label asp-for="Code">Ma TK</label>
                <span asp-validation-for="Code" class="text-danger"></span>
            </div>

            <div class="form-floating mb-3">
                <input asp-for="Name" class="form-control" placeholder="Ten TK" />
                <label asp-for="Name">Ten TK</label>
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>

            <div class="form-floating mb-3">
                <select asp-for="Type" asp-items="Html.GetEnumSelectList<AccountingVAS.Web.Models.AccountType>()" class="form-select">
                </select>
                <label asp-for="Type">Loai TK</label>
                <span asp-validation-for="Type" class="text-danger"></span>
            </div>

            <div class="form-floating mb-3">
                <select asp-for="ParentId" asp-items="parentOptions" class="form-select"></select>
                <label asp-for="ParentId">Tai khoan cha</label>
                <span asp-validation-for="ParentId" class="text-danger"></span>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">Luu</button>
                <button type="button"
                        class="btn btn-outline-secondary"
                        hx-on:click="document.getElementById('account-form-container').innerHTML = '';">
                    Huy
                </button>
            </div>
        </form>
    </div>
</div>

<partial name="_ValidationScriptsPartial" />
