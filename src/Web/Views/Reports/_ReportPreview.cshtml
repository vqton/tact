@model Web.Models.Reports.FinancialReportVm

<div class="card">
    <div class="card-body">
        @if (Model.WebReport is null)
        {
            <div class="alert alert-warning mb-0">
                Chưa có dữ liệu báo cáo.
            </div>
        }
        else
        {
            @await Model.WebReport.Render()
        }
    </div>
</div>
