@model Web.Models.Ledger.LedgerFilterVm

<div class="table-responsive">
    <table class="table table-striped table-hover align-middle">
        <thead class="table-light">
            <tr>
                <th style="width: 140px;">Ngày</th>
                <th style="width: 180px;">Số chứng từ</th>
                <th>Nội dung</th>
                <th style="width: 220px;">Tài khoản</th>
                <th style="width: 150px;" class="text-end">Nợ (VND)</th>
                <th style="width: 150px;" class="text-end">Có (VND)</th>
            </tr>
        </thead>
        <tbody>
            @if (Model.Rows.Count == 0)
            {
                <tr>
                    <td colspan="6" class="text-center text-muted py-4">Không có dữ liệu sổ cái.</td>
                </tr>
            }
            else
            {
                @foreach (var row in Model.Rows)
                {
                    <tr>
                        <td>@row.Date.ToString("dd/MM/yyyy")</td>
                        <td>@row.VoucherRef</td>
                        <td>@row.Description</td>
                        <td>@row.AccountCode - @row.AccountName</td>
                        <td class="text-end">@row.Debit.ToString("N0")</td>
                        <td class="text-end">@row.Credit.ToString("N0")</td>
                    </tr>
                }
            }
        </tbody>
        @if (Model.Rows.Count > 0)
        {
            var totalDebit = Model.Rows.Sum(x => x.Debit);
            var totalCredit = Model.Rows.Sum(x => x.Credit);
            <tfoot class="table-light">
                <tr>
                    <th colspan="4" class="text-end">Tổng</th>
                    <th class="text-end">@totalDebit.ToString("N0")</th>
                    <th class="text-end">@totalCredit.ToString("N0")</th>
                </tr>
            </tfoot>
        }
    </table>
</div>
